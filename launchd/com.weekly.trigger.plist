<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.weekly.trigger</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__WEEKLY_REPORT_RUNTIME__/pipeline/check_trigger.sh</string>
  </array>
  <key>StartInterval</key><integer>180</integer>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__WEEKLY_REPORT_PATH__</string>
  </dict>
  <key>StandardOutPath</key><string>__WEEKLY_REPORT_RUNTIME__/output/logs/launchd_trigger.log</string>
  <key>StandardErrorPath</key><string>__WEEKLY_REPORT_RUNTIME__/output/logs/launchd_trigger.log</string>
  <key>WorkingDirectory</key><string>__WEEKLY_REPORT_RUNTIME__</string>
</dict>
</plist>
