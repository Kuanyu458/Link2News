# 複製到 ~/.config/weekly-report/secrets.env 並填入實際值，然後 chmod 600
# mkdir -p ~/.config/weekly-report && cp secrets.env.example ~/.config/weekly-report/secrets.env

# LINE Messaging API（LINE Developers Console → Messaging API 頁 → Issue token）
LINE_CHANNEL_ACCESS_TOKEN=

# Collector 的共享密鑰（與 `wrangler secret put API_SECRET` 填的相同）
COLLECTOR_API_SECRET=

# GitHub Personal Access Token（scope: public_repo，用於自動 star）
GITHUB_TOKEN=

# 只有 llm.backend 設為 "api" 時才需要
# ANTHROPIC_API_KEY=
